# Hermes Docker Environment (COPY TO .env.hermes AND FILL IN VALUES)

# Discord Bot Token (get from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Allowed Discord User IDs (comma-separated, your user ID only)
DISCORD_ALLOWED_USERS=your_discord_user_id

# Anthropic API Key (dedicated key for Hermes, NOT your Claude Code key)
ANTHROPIC_API_KEY=your_anthropic_api_key_for_hermes

# Jeli Postgres (for future integration)
POSTGRES_PASSWORD=generate_strong_password_here

# Jeli Scoped MCP (future integration)
SCOPED_MCP_API_KEY=generate_via_python_secrets_token_urlsafe
SCOPED_MCP_DB_URL=postgresql://ob1_app:${POSTGRES_PASSWORD}@jeli-postgres:5432/openbrain
