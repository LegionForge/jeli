#!/usr/bin/env bash
# Pre-push scrub: scan every commit being pushed, not just the working tree.
#
# A clean tree is not a clean push — `git push` uploads all ancestor commits.
# This hook greps the full content of every commit that would be uploaded for
# LAN IPs, SSH user@host patterns, key paths, and home-directory paths.
# Added after the 2026-07-02 jeli incident (pre-scrub history republished).
#
# Enable once per clone:  git config core.hooksPath .githooks

set -euo pipefail

PATTERN='10\.[0-9]+\.[0-9]+\.[0-9]+|192\.168\.[0-9]+\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]+\.[0-9]+|ssh[^"]*@[a-z0-9.-]+|@[a-z0-9-]+\.local|id_ed25519|id_rsa|/Users/[a-z]'

fail=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    # Deleting a remote ref pushes nothing.
    [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New remote branch: scan everything not already on any remote.
        range_args=("$local_sha" --not --remotes)
    else
        range_args=("$remote_sha..$local_sha")
    fi

    commits=$(git rev-list "${range_args[@]}")
    [ -z "$commits" ] && continue

    # shellcheck disable=SC2086
    # ':(exclude).githooks' — the pattern definition itself self-matches.
    hits=$(git grep -l -E "$PATTERN" $commits -- ':(exclude).githooks' 2>/dev/null || true)
    if [ -n "$hits" ]; then
        echo "✋ pre-push scrub: sensitive patterns found in commits being pushed:" >&2
        echo "$hits" | sed 's/^/   /' >&2
        echo "   (LAN IP / ssh user@host / key path / home path)" >&2
        echo "   Inspect: git grep -nE '<pattern>' <commit> -- <file>" >&2
        echo "   Bypass ONLY for verified false positives: git push --no-verify" >&2
        fail=1
    fi
done

exit $fail
