# Jeli Scoped MCP Server Configuration

# Database (OB1 openbrain instance)
SCOPED_MCP_DB_URL=postgresql://ob1_app:password@127.0.0.1:5433/openbrain
SCOPED_MCP_DB_MIN_SIZE=5
SCOPED_MCP_DB_MAX_SIZE=20

# Security
SCOPED_MCP_API_KEY=your-generated-key-here

# Embedding Service
SCOPED_MCP_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
# OR for Ollama (Phase 2):
# SCOPED_MCP_EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=nomic-embed-text

# Server
SCOPED_MCP_TRANSPORT=stdio
SCOPED_MCP_LOG_LEVEL=INFO
SCOPED_MCP_LOG_FORMAT=json

# Optional: Health checks & metrics
SCOPED_MCP_ENABLE_METRICS=true
SCOPED_MCP_METRICS_PORT=8000

# Development
DEBUG=false
