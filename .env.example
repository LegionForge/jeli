# Jeli Scoped MCP Server Configuration

# Database (jeli-postgres Docker container)
SCOPED_MCP_DB_URL=postgresql://jeli_app:password@127.0.0.1:5442/jeli
SCOPED_MCP_DB_MIN_SIZE=5
SCOPED_MCP_DB_MAX_SIZE=20

# Security
SCOPED_MCP_API_KEY=your-generated-key-here
SCOPED_MCP_CHAIN_KEY=your-generated-chain-key-here

# Embedding Service (default: Ollama local — sovereignty-first)
SCOPED_MCP_EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Model must emit 1024 dims — matches the pgvector HNSW index standard.
# Other 1024-dim options: qwen3-embedding, snowflake-arctic-embed, BAAI/bge-m3
# (nomic-embed-text is 768-dim and will not work without a schema migration)
OLLAMA_MODEL=snowflake-arctic-embed2
# OR for OpenAI (cloud, opt-in — truncated to 1024 via matryoshka):
# SCOPED_MCP_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here

# Server
SCOPED_MCP_TRANSPORT=stdio
SCOPED_MCP_LOG_LEVEL=INFO
SCOPED_MCP_LOG_FORMAT=json

# Optional: Health checks & metrics
SCOPED_MCP_ENABLE_METRICS=true
SCOPED_MCP_METRICS_PORT=8000

# Development
DEBUG=false
